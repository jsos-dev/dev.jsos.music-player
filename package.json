{
    "name": "music-player",
    "version": "1.1.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "start": "node server.js",
        "git:tag": "node -e \"const v=require('./package.json').version;const{execSync}=require('child_process');execSync('git tag v'+v+' && git push origin v'+v,{stdio:'inherit'});console.log('Tagged and pushed v'+v)\"",
        "jsh:install": "(cd node_modules >/dev/null 2>&1) || pnpm install",
        "jsh:start2": "(cd dist >/dev/null 2>&1) || npm run build && npm start",
        "jsh:start": "node server.js"
    },
    "dependencies": {
        "express": "^4.18.0",
        "music-metadata": "^10.6.0"
    },
    "devDependencies": {
        "@base-ui/react": "^1.5.0",
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-react": "^4.0.0",
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.0.0",
        "lucide-react": "^1.0.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "tailwind-merge": "^3.0.0",
        "tailwindcss": "^4.0.0",
        "tw-animate-css": "^1.4.0",
        "vite": "^6.0.0"
    },
    "repository": {
      "type": "git",
      "url": "https://github.com/jsos-dev/dev.jsos.music-player"
    },
    "bugs": {
      "url": "https://github.com/jsos-dev/dev.jsos.music-player/issues"
    },
    "author": {
      "name": "JSOS",
      "url": "https://github.com/jsos-dev"
    },
    "jsos": {
        "id": "dev.jsos.music-player",
        "name": { "en": "Music Player", "zh-CN": "音乐播放器" },
        "description": { "en": "A music player for playing audio files", "zh-CN": "用于播放音频文件的音乐播放器" },
        "icon": "icon.svg",
        "startCommand": "npm run jsh:start",
        "installCommand": "npm run jsh:install",
        "widgets": [
            {
                "id": "favorites",
                "name": { "en": "My Favorites", "zh-CN": "我的收藏" },
                "description": { "en": "Play your favorite songs from the desktop widget", "zh-CN": "在桌面小组件播放你收藏的歌曲" },
                "url": "/#/widget/favorites",
                "cols": 3,
                "rows": 1,
                "background": { "type": "frosted", "opacity": 80, "blur": 12 }
            }
        ]
    }
}
